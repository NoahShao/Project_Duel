        {
            "Id": 19,
            "RoleName": "张角",
            "Faction": "群",
            "Suit": "黑桃",
            "Rank": "K",
            "ExpansionPack": "基础",
            "SkillName1": "黄天当立",
            "SkillDesc1": "【攻击技】\n♣同花：你造成2点雷电伤害，然后你摸一张牌。\n♠同花：你造成3点雷电伤害。",
            "SkillTags1": [
                "攻击技"
            ],
            "SkillName2": "太平要术",
            "SkillDesc2": "当你结算造成雷电伤害时，你可以获得X层的“疗愈”效果，X为你此次造成的雷电伤害的1/2（向上取整）。",
            "SkillTags2": [],
            "SkillName3": "",
            "SkillDesc3": "",
            "SkillTags3": [],
