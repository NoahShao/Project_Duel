        },
        {
            "Id": 21,
            "RoleName": "张梁",
            "Faction": "群",
            "Suit": "黑桃",
            "Rank": "J",
            "ExpansionPack": "基础",
            "SkillName1": "妖术",
            "SkillDesc1": "当你恢复生命后，你可以造成1点通用伤害。",
            "SkillTags1": [],
            "SkillName2": "集军",
            "SkillDesc2": "在你的主要阶段中限一次，你可以将任意张手牌放置在此角色牌上。在你的弃牌阶段结束时，若此角色牌上的牌的点数之和不小于36，你可以将此角色上的所有牌置入弃牌堆，并造成6点雷电伤害。若你以此法置入弃牌堆的牌颜色相同，你改为造成8点雷电伤害。",
