        {
            "Id": 20,
            "RoleName": "张宝",
            "Faction": "群",
            "Suit": "黑桃",
            "Rank": "Q",
            "ExpansionPack": "基础",
            "SkillName1": "影兵",
            "SkillDesc1": "【破军技】\n在你的主要阶段或出牌阶段中，你可以使你的士气上限+1，并且本回合中当你出牌时，你使用的小3点角色不会翻面。持续技，强制技，在你的弃牌阶段结束时，若所有玩家具有的“妖风”效果的层数不小于2，移除所有玩家具有的“妖风”效果，并使此技能的使用次数+1。",
            "SkillTags1": [
                "破军技"
            ],
            "SkillName2": "妖风大作",
            "SkillDesc2": "在你的主要阶段中，你可以减少1点士气上限，并使一名玩家获得一层“妖风”效果。",
            "SkillTags2": [],
            "SkillName3": "",
